# OpenSearch Configuration
OPENSEARCH_ENDPOINT=http://mmr-test-v1-prod.sstk-search-prod.ct.shuttercloud.org
OPENSEARCH_PHOTO_INDEX=web-index-v9
OPENSEARCH_CONVERSATION_INDEX=gen-aperture-conversations

# OpenSearch Guardrails
# If unset, read-only mode auto-enables for hosts in Settings.opensearch_readonly_hosts.
# Set explicitly to force behavior.
OPENSEARCH_READONLY=true

# Session Configuration
SESSION_TIMEOUT_MINUTES=30

# Bifrost AI Gateway
BIFROST_API_KEY=
BIFROST_BASE_URL=https://bifrost.shuttercorp.net/openai
BIFROST_MODEL=gpt-4.1

# Environment
ENVIRONMENT=development
